
<% if user_signed_in? %>
 <%= link_to "Create a new post", new_post_path, class: "new-post button" %>
<% end %>

<% if @posts.empty? %>
 <h2 class="empty-posts">No posts to view.</h2>
 <% end %>

<br>
<% @posts.each do |post| %>
<div class="post">
<h2><%= post.title %></h2>
<hr>
<p class="post-content"><%= post.content %></p>
<hr class="author-hr-line">
<% if user_signed_in? %>
<p>Published by: <strong><%= post.user.name.capitalize %> <span>&#8226;</span> <%= distance_of_time_in_words_to_now(post.created_at) %> ago</strong></p>
<% else %>
<%= link_to "Sign in to view post author", sign_in_path, class: "link" %>
<% end %>
</div>
<% end %>